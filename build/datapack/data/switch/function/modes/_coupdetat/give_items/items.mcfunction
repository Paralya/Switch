
#> switch:modes/_coupdetat/give_items/items
#
# @within	switch:modes/_coupdetat/give_items with storage switch:layout out
#
# @args		s0 (unknown)
#			s1 (unknown)
#			s2 (unknown)
#			s3 (unknown)
#

$loot replace entity @s $(s0) loot switch:i/stardust_sword
$loot replace entity @s $(s1) loot switch:i/stardust_apple
$item replace entity @s $(s2) with tnt 2
$item replace entity @s $(s3) with flint_and_steel

