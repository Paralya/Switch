
#> switch:modes/cigogne/give_items/items
#
# @executed	as @a[tag=!detached]
#
# @within	switch:modes/cigogne/give_items with storage switch:layout out
#
# @args		s0 (unknown)
#			s1 (unknown)
#			s2 (unknown)
#			s3 (unknown)
#

$item replace entity @s $(s0) with golden_apple 4
$item replace entity @s $(s1) with iron_sword[enchantments={fire_aspect:1}]
$item replace entity @s $(s2) with bow[enchantments={flame:1}]
$item replace entity @s $(s3) with arrow 32

